# dependencies
node_modules

# next.js
.next
out

# env (never commit secrets / local config)
.env
.env.local
# Docker runtime env (may hold an API key — commit only .env.docker.example)
.env.docker

# live database (commit the seed *source*, not the live db)
/data/app.db
# transient SQLite WAL sidecars (any db under /data)
/data/*.db-wal
/data/*.db-shm
# NOTE: a committed seed template (e.g. /data/seed-template.db) is intentionally
# NOT ignored — it can travel with the repo as selectable default data.

# design handoff reference (large; kept locally for context, not committed)
design-ref

# os / editor
.DS_Store
*.log
.vercel
.env*
