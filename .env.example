# ── StudyCircle configuration (copy to .env and edit) ─────────────────────────
# All config is env-only — no hardcoded paths or limits in the code.

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3000

# ── Database ────────────────────────────────────────────────────────────────
# SQLite file. Kept under ./data so a future `docker compose` can mount it.
DB_PATH=./data/app.db

# ── LLM provider (Explore / AI search — server-side only) ─────────────────────
# Which provider the server uses. "gemini" (default) or "anthropic".
LLM_PROVIDER=gemini
# Provide the key for whichever provider you select. Leave the other blank.
GEMINI_API_KEY=
ANTHROPIC_API_KEY=
# Optional model overrides (defaults chosen in code to current models if unset).
# GEMINI_MODEL=
# ANTHROPIC_MODEL=

# ── Free-trial caps (drive enforcement, meters, AND copy — change here only) ──
BOOKMARK_CAP=5
JOIN_GROUP_CAP=2
SEARCH_WEEKLY_CAP=7
# Follow is uncapped by design. Set a number to meter it too (optional).
# FOLLOW_CAP=
