# ── StudyCircle configuration (copy to .env and edit) ─────────────────────────
# All config is env-only — no hardcoded paths or limits in the code.

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3000

# ── App frame aspect ratio ───────────────────────────────────────────────────
# "device" (default) = full-bleed, fills the viewport (copies the device ratio).
# "W:H" = lock the frame to that ratio, centered + letterboxed (e.g. 9:16, 3:4).
ASPECT_RATIO=device

# ── Database ────────────────────────────────────────────────────────────────
# SQLite file. Kept under ./data so a future `docker compose` can mount it.
DB_PATH=./data/app.db

# Default-seed TEMPLATE. On FIRST run the template's world is copied into DB_PATH
# and the user layer starts clean. The committed default is the large "enhanced"
# dataset (110 profiles, 20 groups, 234 posts, 551 comments) — rebuild it from
# src/data/enhanced-seed.sql with `npm run db:build-seed`.
# Blank it out to fall back to the small src/data/seed.json instead.
SEED_DB_PATH=./data/enhanced-seed.db

# ── LLM provider (Explore / AI search — server-side only) ─────────────────────
# Which provider the server uses. "gemini" (default) or "anthropic".
LLM_PROVIDER=gemini
# Provide the key for whichever provider you select. Leave the other blank.
GEMINI_API_KEY=
ANTHROPIC_API_KEY=
# Optional model overrides (defaults: gemini-2.5-flash / claude-haiku-4-5).
# GEMINI_MODEL=
# ANTHROPIC_MODEL=
# How many search_corpus rows the LLM ranks per search.
LLM_CANDIDATE_ROWS=20
# Per-demo-session LLM token budget. When exceeded, Explore search is blocked
# with an "AI tokens exhausted" toast. Resets on logout. Lower it to demo the cap.
LLM_SESSION_TOKEN_BUDGET=20000

# ── Free-trial caps (drive enforcement, meters, AND copy — change here only) ──
BOOKMARK_CAP=5
JOIN_GROUP_CAP=2
SEARCH_WEEKLY_CAP=7
# Weekly write budget — post/comment/reply/repost/quote all draw from this.
POST_WEEKLY_CAP=5
# Follow is uncapped by design. Set a number to meter it too (optional).
# FOLLOW_CAP=
