# ── StudyCircle — Docker runtime config ──────────────────────────────────────
# Copy this to `.env.docker`, edit, and pass it in:  --env-file .env.docker
# (or it's picked up automatically by `docker compose`). Every var here is read
# at RUNTIME — edit this file and RESTART the container; no rebuild needed.
#
# The ONLY exception is NEXT_PUBLIC_NAV_ICON_EXT (logo file extension), which is
# baked in at build time. To change it you must rebuild:
#     docker build --build-arg NEXT_PUBLIC_NAV_ICON_EXT=svg -t studycircle .
#
# NOTE: DB_PATH and SEED_DB_PATH are intentionally NOT set here. The image already
# points them at the right in-container paths (/app/data/app.db live DB inside the
# volume; /app/seed/enhanced-seed.db template OUTSIDE the volume). Overriding
# SEED_DB_PATH to a ./data path would let the volume shadow it and break seeding.

# ── Server ──────────────────────────────────────────────────────────────────
# Port the app listens on INSIDE the container. If you change it, change the
# `docker run -p HOST:THIS` mapping (and compose `ports`) to match.
PORT=3000

# ── App frame ────────────────────────────────────────────────────────────────
# "device" (full-bleed) or a "W:H" ratio like 9:16 / 3:4 (letterboxed).
ASPECT_RATIO=device

# ── Fonts (Google Fonts family name, or a /fonts/... file under public/) ──────
# FONT_DISPLAY=Baloo Da 2
# FONT_BODY=Be Vietnam Pro
# FONT_BENGALI=

# ── Free-trial caps (drive enforcement + on-screen meters + copy together) ────
BOOKMARK_CAP=5
JOIN_GROUP_CAP=2
SEARCH_WEEKLY_CAP=7
POST_WEEKLY_CAP=5
# FOLLOW_CAP=        # blank = uncapped; set a number to meter follows too

# ── LLM (Explore / AI search — server-side only) ─────────────────────────────
# Works WITHOUT a key (keyword fallback + demo trending). Add a key to enable
# real AI search. SECRET — never commit a filled-in .env.docker.
LLM_PROVIDER=gemini
GEMINI_API_KEY=
ANTHROPIC_API_KEY=
# LLM_MODEL=                 # single knob; overrides the per-provider default
LLM_CANDIDATE_ROWS=20
LLM_SESSION_TOKEN_BUDGET=20000
# AI_DEBUG=1                 # show a step-by-step popup of why an AI call failed
